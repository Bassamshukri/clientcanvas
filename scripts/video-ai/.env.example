# Pexels API Key (https://www.pexels.com/api/new/)
PEXELS_API_KEY=your_pexels_key_here

# Hugging Face API Token (https://huggingface.co/settings/tokens)
# Use a token with "Inference API" permissions
HF_API_TOKEN=your_hf_token_here

# Optional: Default voice for Edge-TTS
# Run `edge-tts --list-voices` to see all available voices
TTS_VOICE=en-US-AvaNeural
